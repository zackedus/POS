generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant Core ───────────────────────────────────
// Every business entity is scoped by tenant_id (directly or via outlet).
// Row-level isolation enforced at application layer + composite unique keys.

model Tenant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  contactPhone String?  @map("contact_phone")
  logoUrl      String?  @map("logo_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  outlets      Outlet[]
  users        User[]
  products     Product[]
  categories   Category[]
  units        Unit[]
  suppliers    Supplier[]
  promoRules   PromoRule[]
  auditLogs    AuditLog[]
  productBundles         ProductBundle[]
  productUnitConversions ProductUnitConversion[]
  syncQueueEntries       SyncQueueEntry[]
  onlineOrders           OnlineOrder[]
  onlineOrderSequences   OnlineOrderSequence[]
  expenses               Expense[]
  purchaseOrders               PurchaseOrder[]
  purchaseOrderSequences       PurchaseOrderSequence[]
  purchaseOrderReturnSequences PurchaseOrderReturnSequence[]
  purchaseOrderReturns         PurchaseOrderReturn[]
  tenantSettings               TenantSettings?
  customers                    Customer[]
  loyaltyPointLedger           LoyaltyPointLedger[]
  receivables                  Receivable[]
  payables                     Payable[]
  customerDeposits             CustomerDeposit[]
  customerCreditAuditLogs      CustomerCreditAuditLog[]

  @@map("tenants")
}

/// Per-tenant operational settings (PPN, Midtrans tenant override).
model TenantSettings {
  id                   String   @id @default(uuid())
  tenantId             String   @unique @map("tenant_id")
  ppnEnabled           Boolean  @default(false) @map("ppn_enabled")
  ppnRatePercent       Decimal  @default(11) @map("ppn_rate_percent") @db.Decimal(5, 2)
  midtransServerKey           String?  @map("midtrans_server_key")
  midtransIsProduction        Boolean  @default(false) @map("midtrans_is_production")
  weeklyReportEmailEnabled    Boolean  @default(false) @map("weekly_report_email_enabled")
  loyaltyPointsEnabled        Boolean  @default(true) @map("loyalty_points_enabled")
  loyaltyEarnRateIdr          Int      @default(10000) @map("loyalty_earn_rate_idr")
  loyaltyRedeemEnabled        Boolean  @default(true) @map("loyalty_redeem_enabled")
  loyaltyRedeemValueIdr       Int      @default(1000) @map("loyalty_redeem_value_idr")
  loyaltyRedeemMaxPercent     Int      @default(50) @map("loyalty_redeem_max_percent")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Outlet {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  name            String
  code            String
  address         String?
  phone           String?
  operatingHours  String?  @map("operating_hours")
  isDefault       Boolean  @default(false) @map("is_default")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  inventory         InventoryItem[]
  transactions      Transaction[]
  shifts            Shift[]
  stockMovements    StockMovement[]
  heldTransactions  HeldTransaction[]
  userOutlets       UserOutlet[]
  bundlePolicies    ProductBundleOutletPolicy[]
  syncQueueEntries  SyncQueueEntry[]
  onlineOrders      OnlineOrder[]
  expenses          Expense[]
  purchaseOrders    PurchaseOrder[]
  receivables       Receivable[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("outlets")
}

// ─── Auth & RBAC ─────────────────────────────────────────
// Users belong to one tenant; outlet access via user_outlets junction.
// Role enum covers MVP; granular permissions deferred to Phase 2.

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         UserRole @default(CASHIER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  transactions        Transaction[]
  shifts              Shift[]
  userOutlets         UserOutlet[]
  stockMovements      StockMovement[]
  heldTransactions    HeldTransaction[]
  auditLogs           AuditLog[]
  adjustmentsCreated  TransactionAdjustment[] @relation("AdjustmentCreatedBy")
  adjustmentsApproved TransactionAdjustment[] @relation("AdjustmentApprovedBy")
  syncQueueEntries    SyncQueueEntry[]
  expensesCreated          Expense[]
  purchaseOrdersCreated    PurchaseOrder[]         @relation("PurchaseOrderCreatedBy")
  purchaseOrdersSubmitted  PurchaseOrder[]         @relation("PurchaseOrderSubmittedBy")
  purchaseOrderReceipts    PurchaseOrderReceipt[]
  purchaseOrderReturns     PurchaseOrderReturn[]
  receivablePaymentsRecorded ReceivablePayment[] @relation("ReceivablePaymentRecordedBy")
  payablePaymentsRecorded    PayablePayment[]    @relation("PayablePaymentRecordedBy")
  depositTransactionsRecorded DepositTransaction[] @relation("DepositTransactionRecordedBy")
  loyaltyPointLedgerRecorded  LoyaltyPointLedger[]
  creditAuditLogsRecorded     CustomerCreditAuditLog[] @relation("CreditAuditRecordedBy")
  creditAuditLogsApproved     CustomerCreditAuditLog[] @relation("CreditAuditApprovedBy")

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

/// Junction: restricts cashier/manager to assigned outlets (Owner sees all).
model UserOutlet {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  outletId String @map("outlet_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([userId, outletId])
  @@map("user_outlets")
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  INVENTORY
  ACCOUNTANT
}

// ─── Catalog ─────────────────────────────────────────────

model Unit {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  symbol    String
  createdAt DateTime @default(now()) @map("created_at")

  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  products            Product[]
  sellUnitConversions ProductUnitConversion[]
  transactionItems    TransactionItem[]
  heldTransactionItems HeldTransactionItem[]
  purchaseOrderItems  PurchaseOrderItem[]

  @@unique([tenantId, symbol])
  @@map("units")
}

model Category {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  parentId  String?  @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  parent     Category?   @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   Category[]  @relation("CategoryTree")
  products   Product[]
  promoRules PromoRule[]

  @@index([tenantId, parentId])
  @@index([tenantId, sortOrder, name])
  @@map("categories")
}

model Supplier {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  products       Product[]
  purchaseOrders PurchaseOrder[]
  payables       Payable[]

  @@index([tenantId, name])
  @@map("suppliers")
}

model Product {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  categoryId   String?  @map("category_id")
  unitId       String?  @map("unit_id")
  supplierId   String?  @map("supplier_id")
  parentProductId String? @map("parent_product_id")
  sku          String
  barcode      String?
  name         String
  variantLabel String? @map("variant_label")
  hasVariants  Boolean  @default(false) @map("has_variants")
  price        Decimal  @db.Decimal(15, 2)
  costPrice    Decimal  @default(0) @map("cost_price") @db.Decimal(15, 2)
  taxInclusive Boolean  @default(true) @map("tax_inclusive")
  isActive     Boolean  @default(true) @map("is_active")
  sellOnline           Boolean  @default(false) @map("sell_online")
  imageUrl             String?  @map("image_url")
  webPlaceholderKey    String?  @map("web_placeholder_key")
  moq                  Decimal  @default(1) @db.Decimal(15, 3)
  orderStep            Decimal  @default(1) @map("order_step") @db.Decimal(15, 3)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  category             Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit                 Unit?                 @relation(fields: [unitId], references: [id], onDelete: SetNull)
  supplier             Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  parentProduct        Product?              @relation("ProductVariants", fields: [parentProductId], references: [id], onDelete: SetNull)
  variants             Product[]             @relation("ProductVariants")
  bundleDefinition     ProductBundle?        @relation("BundleProduct")
  bundleComponents     ProductBundleItem[]   @relation("BundleComponentProduct")
  unitConversions      ProductUnitConversion[]
  inventory            InventoryItem[]
  items                TransactionItem[]
  stockMovements       StockMovement[]
  heldTransactionItems HeldTransactionItem[]
  promoRules           PromoRule[]
  onlineOrderItems     OnlineOrderItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  purchaseOrderReceiptLines PurchaseOrderReceiptLine[]
  purchaseOrderReturnLines  PurchaseOrderReturnLine[]

  @@unique([tenantId, sku])
  @@index([tenantId, barcode])
  @@index([tenantId, categoryId])
  @@index([tenantId, parentProductId])
  @@index([tenantId, sellOnline, isActive])
  @@index([tenantId, isActive, hasVariants, categoryId])
  @@map("products")
}

model ProductBundle {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  bundleProductId String   @unique @map("bundle_product_id")
  isActive        Boolean  @default(true) @map("is_active")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  bundleProduct Product            @relation("BundleProduct", fields: [bundleProductId], references: [id], onDelete: Cascade)
  items         ProductBundleItem[]
  outletPolicies ProductBundleOutletPolicy[]

  @@index([tenantId, isActive])
  @@map("product_bundles")
}

model ProductBundleOutletPolicy {
  id        String   @id @default(uuid())
  bundleId  String   @map("bundle_id")
  outletId  String   @map("outlet_id")
  isActive  Boolean  @default(true) @map("is_active")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bundle ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  outlet Outlet        @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([bundleId, outletId])
  @@index([outletId, isActive])
  @@map("product_bundle_outlet_policies")
}

model ProductBundleItem {
  id                 String   @id @default(uuid())
  bundleId           String   @map("bundle_id")
  componentProductId String   @map("component_product_id")
  quantity           Decimal  @db.Decimal(15, 3)
  createdAt          DateTime @default(now()) @map("created_at")

  bundle           ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  componentProduct Product       @relation("BundleComponentProduct", fields: [componentProductId], references: [id], onDelete: Restrict)

  @@unique([bundleId, componentProductId])
  @@index([componentProductId])
  @@map("product_bundle_items")
}

model ProductUnitConversion {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  productId        String   @map("product_id")
  sellUnitId       String   @map("sell_unit_id")
  conversionToBase Decimal  @map("conversion_to_base") @db.Decimal(15, 3)
  isPurchaseUnit   Boolean  @default(false) @map("is_purchase_unit")
  isSellUnit       Boolean  @default(true) @map("is_sell_unit")
  isDefaultSell    Boolean  @default(false) @map("is_default_sell")
  sellStep         Decimal? @map("sell_step") @db.Decimal(15, 3)
  minQty           Decimal? @map("min_qty") @db.Decimal(15, 3)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sellUnit Unit    @relation(fields: [sellUnitId], references: [id], onDelete: Restrict)

  @@unique([productId, sellUnitId])
  @@index([tenantId, productId, isDefaultSell])
  @@index([tenantId, productId, isPurchaseUnit])
  @@map("product_unit_conversions")
}

// ─── Inventory ───────────────────────────────────────────
// inventory_items = current stock snapshot per outlet.
// stock_movements = immutable ledger (source of truth for audit).

model InventoryItem {
  id        String   @id @default(uuid())
  outletId  String   @map("outlet_id")
  productId String   @map("product_id")
  quantity  Decimal  @default(0) @db.Decimal(15, 3)
  minStock  Decimal  @default(0) @map("min_stock") @db.Decimal(15, 3)
  updatedAt DateTime @updatedAt @map("updated_at")

  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([outletId, productId])
  @@index([outletId, quantity])
  @@map("inventory_items")
}

model StockMovement {
  id             String            @id @default(uuid())
  outletId       String            @map("outlet_id")
  productId      String            @map("product_id")
  type           StockMovementType
  quantity       Decimal           @db.Decimal(15, 3) // positive = in, negative = out
  quantityBefore Decimal           @map("quantity_before") @db.Decimal(15, 3)
  quantityAfter  Decimal           @map("quantity_after") @db.Decimal(15, 3)
  referenceType  String?           @map("reference_type") // e.g. "transaction", "adjustment"
  referenceId    String?           @map("reference_id")
  notes          String?
  createdById    String            @map("created_by_id")
  createdAt      DateTime          @default(now()) @map("created_at")

  outlet    Outlet  @relation(fields: [outletId], references: [id], onDelete: Restrict)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([outletId, productId, createdAt])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

enum StockMovementType {
  SALE
  SALE_ONLINE
  PURCHASE
  PURCHASE_RETURN
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  VOID_RESTORE
  OPNAME
}

// ─── Purchase Orders (Distributor) ───────────────────────
// PO lifecycle: DRAFT → ORDERED → PARTIALLY_RECEIVED → RECEIVED | CANCELLED

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrderSequence {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  sequenceDate DateTime @map("sequence_date") @db.Date
  lastValue    Int      @default(0) @map("last_value")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, sequenceDate])
  @@map("purchase_order_sequences")
}

model PurchaseOrder {
  id                 String              @id @default(uuid())
  tenantId           String              @map("tenant_id")
  outletId           String              @map("outlet_id")
  supplierId         String              @map("supplier_id")
  orderNo            String              @map("order_no")
  status             PurchaseOrderStatus @default(DRAFT)
  notes              String?
  orderedAt          DateTime?           @map("ordered_at")
  expectedDeliveryAt DateTime?           @map("expected_delivery_at")
  receivedAt         DateTime?           @map("received_at")
  cancelledAt        DateTime?           @map("cancelled_at")
  createdById        String              @map("created_by_id")
  submittedById      String?             @map("submitted_by_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  outlet      Outlet                 @relation(fields: [outletId], references: [id], onDelete: Restrict)
  supplier    Supplier               @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy   User                   @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  submittedBy User?                  @relation("PurchaseOrderSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  items       PurchaseOrderItem[]
  receipts    PurchaseOrderReceipt[]
  returns     PurchaseOrderReturn[]
  payable     Payable?

  @@unique([tenantId, orderNo])
  @@index([tenantId, outletId, status])
  @@index([tenantId, supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(uuid())
  purchaseOrderId  String  @map("purchase_order_id")
  productId        String  @map("product_id")
  unitId           String? @map("unit_id")
  orderedQuantity  Decimal @map("ordered_quantity") @db.Decimal(15, 3)
  receivedQuantity Decimal @default(0) @map("received_quantity") @db.Decimal(15, 3)
  returnedQuantity Decimal @default(0) @map("returned_quantity") @db.Decimal(15, 3)
  unitCost         Decimal @map("unit_cost") @db.Decimal(15, 2)
  lineTotal        Decimal @map("line_total") @db.Decimal(15, 2)
  sortOrder        Int     @default(0) @map("sort_order")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  unit          Unit?         @relation(fields: [unitId], references: [id], onDelete: SetNull)
  receiptLines  PurchaseOrderReceiptLine[]
  returnLines   PurchaseOrderReturnLine[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model PurchaseOrderReceipt {
  id              String   @id @default(uuid())
  purchaseOrderId String   @map("purchase_order_id")
  receivedAt      DateTime @default(now()) @map("received_at")
  notes           String?
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder              @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdBy     User                       @relation(fields: [createdById], references: [id], onDelete: Restrict)
  lines         PurchaseOrderReceiptLine[]

  @@index([purchaseOrderId, receivedAt])
  @@map("purchase_order_receipts")
}

model PurchaseOrderReceiptLine {
  id                  String  @id @default(uuid())
  receiptId           String  @map("receipt_id")
  purchaseOrderItemId String  @map("purchase_order_item_id")
  productId           String  @map("product_id")
  quantityReceived    Decimal @map("quantity_received") @db.Decimal(15, 3)
  unitCost            Decimal @map("unit_cost") @db.Decimal(15, 2)
  baseQuantityAdded   Decimal @map("base_quantity_added") @db.Decimal(15, 3)
  baseCostApplied     Decimal @map("base_cost_applied") @db.Decimal(15, 2)

  receipt           PurchaseOrderReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  purchaseOrderItem PurchaseOrderItem    @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Restrict)
  product           Product              @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([receiptId])
  @@index([purchaseOrderItemId])
  @@map("purchase_order_receipt_lines")
}

enum PurchaseOrderReturnReason {
  DAMAGED
  WRONG_ITEM
  EXCESS
  OTHER
}

enum PurchaseOrderReturnStatus {
  COMPLETED
}

model PurchaseOrderReturnSequence {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  sequenceDate DateTime @map("sequence_date") @db.Date
  lastValue    Int      @default(0) @map("last_value")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, sequenceDate])
  @@map("purchase_order_return_sequences")
}

model PurchaseOrderReturn {
  id              String                    @id @default(uuid())
  tenantId        String                    @map("tenant_id")
  purchaseOrderId String                    @map("purchase_order_id")
  returnNo        String                    @map("return_no")
  status          PurchaseOrderReturnStatus @default(COMPLETED)
  notes           String?
  returnedAt      DateTime                  @default(now()) @map("returned_at")
  createdById     String                    @map("created_by_id")
  createdAt       DateTime                  @default(now()) @map("created_at")

  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder             @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdBy     User                      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  lines         PurchaseOrderReturnLine[]

  @@unique([tenantId, returnNo])
  @@index([purchaseOrderId, returnedAt])
  @@map("purchase_order_returns")
}

model PurchaseOrderReturnLine {
  id                  String                    @id @default(uuid())
  returnId            String                    @map("return_id")
  purchaseOrderItemId String                    @map("purchase_order_item_id")
  productId           String                    @map("product_id")
  quantityReturned    Decimal                   @map("quantity_returned") @db.Decimal(15, 3)
  reason              PurchaseOrderReturnReason
  baseQuantityRemoved Decimal                   @map("base_quantity_removed") @db.Decimal(15, 3)
  unitCost            Decimal                   @map("unit_cost") @db.Decimal(15, 2)
  lineTotal           Decimal                   @map("line_total") @db.Decimal(15, 2)

  returnRecord      PurchaseOrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  purchaseOrderItem PurchaseOrderItem   @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Restrict)
  product           Product             @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([returnId])
  @@index([purchaseOrderItemId])
  @@map("purchase_order_return_lines")
}

// ─── Promo (MVP minimal) ─────────────────────────────────
// Full promo engine (stacking, buy-X-get-Y) deferred to Phase 2.

model PromoRule {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  name        String
  type        PromoType
  value       Decimal       @db.Decimal(15, 2) // percent (0–100) or fixed amount
  applyTo     PromoApplyTo  @default(ALL) @map("apply_to")
  categoryId  String?       @map("category_id")
  productId   String?       @map("product_id")
  minPurchase Decimal?      @map("min_purchase") @db.Decimal(15, 2)
  isActive    Boolean       @default(true) @map("is_active")
  startsAt    DateTime?     @map("starts_at")
  endsAt      DateTime?     @map("ends_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, isActive])
  @@map("promo_rules")
}

enum PromoType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PromoApplyTo {
  ALL
  CATEGORY
  PRODUCT
}

// ─── Customers & Loyalty (Fase 2 MVP) ────────────────────

model Customer {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  phone       String
  email       String?
  memberCode  String   @map("member_code")
  memberSince DateTime @default(now()) @map("member_since")
  notes       String?
  points            Int      @default(0)
  creditLimit       Decimal? @map("credit_limit") @db.Decimal(15, 2)
  autoLimitEnabled  Boolean  @default(true) @map("auto_limit_enabled")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant         Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  addresses      CustomerAddress[]
  loyaltyLedger  LoyaltyPointLedger[]
  transactions   Transaction[]
  onlineOrders   OnlineOrder[]
  receivables    Receivable[]
  deposit        CustomerDeposit?
  creditAuditLogs CustomerCreditAuditLog[]

  @@unique([tenantId, phone])
  @@unique([tenantId, memberCode])
  @@index([tenantId, name])
  @@map("customers")
}

model CustomerAddress {
  id           String   @id @default(uuid())
  customerId   String   @map("customer_id")
  label        String
  addressLine1 String   @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String
  province     String?
  postalCode   String?  @map("postal_code")
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

enum LoyaltyPointType {
  EARN
  REDEEM
  ADJUST
}

model LoyaltyPointLedger {
  id            String           @id @default(uuid())
  tenantId      String           @map("tenant_id")
  customerId    String           @map("customer_id")
  type          LoyaltyPointType
  points        Int
  balanceAfter  Int              @map("balance_after")
  transactionId String?          @map("transaction_id")
  notes         String?
  recordedById  String?          @map("recorded_by_id")
  createdAt     DateTime         @default(now()) @map("created_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  recordedBy  User?        @relation(fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([tenantId])
  @@map("loyalty_point_ledger")
}

enum CustomerCreditAuditAction {
  LIMIT_SET
  LIMIT_AUTO_INCREASE
  OVER_LIMIT_APPROVAL
  CREDIT_SALE
}

model CustomerCreditAuditLog {
  id            String                    @id @default(uuid())
  tenantId      String                    @map("tenant_id")
  customerId    String                    @map("customer_id")
  action        CustomerCreditAuditAction
  oldLimit      Decimal?                  @map("old_limit") @db.Decimal(15, 2)
  newLimit      Decimal?                  @map("new_limit") @db.Decimal(15, 2)
  amount        Decimal?                  @db.Decimal(15, 2)
  transactionId String?                   @map("transaction_id")
  approvedById  String?                   @map("approved_by_id")
  recordedById  String?                   @map("recorded_by_id")
  notes         String?
  createdAt     DateTime                  @default(now()) @map("created_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  approvedBy  User?        @relation("CreditAuditApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  recordedBy  User?        @relation("CreditAuditRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([tenantId])
  @@map("customer_credit_audit_logs")
}

// ─── Transactions ────────────────────────────────────────
// Completed transactions are immutable; void/refund via transaction_adjustments.
// clientRequestId enables idempotent checkout from mobile offline queue.

model Transaction {
  id              String            @id @default(uuid())
  outletId        String            @map("outlet_id")
  cashierId       String            @map("cashier_id")
  shiftId         String?           @map("shift_id")
  customerId      String?           @map("customer_id")
  receiptNo       String            @map("receipt_no")
  clientRequestId String?           @unique @map("client_request_id")
  status          TransactionStatus @default(COMPLETED)
  subtotal        Decimal           @db.Decimal(15, 2)
  discount        Decimal           @default(0) @db.Decimal(15, 2)
  tax             Decimal           @default(0) @db.Decimal(15, 2)
  total           Decimal           @db.Decimal(15, 2)
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  completedAt     DateTime?         @map("completed_at")

  outlet      Outlet                  @relation(fields: [outletId], references: [id], onDelete: Restrict)
  cashier     User                    @relation(fields: [cashierId], references: [id], onDelete: Restrict)
  shift       Shift?                  @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  customer    Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items       TransactionItem[]
  payments    Payment[]
  adjustments TransactionAdjustment[]
  receivable  Receivable?
  loyaltyLedger LoyaltyPointLedger[]
  creditAuditLogs CustomerCreditAuditLog[]

  @@unique([outletId, receiptNo])
  @@index([outletId, createdAt])
  @@index([outletId, status])
  @@index([cashierId, createdAt])
  @@index([customerId])
  @@map("transactions")
}

model TransactionItem {
  id             String  @id @default(uuid())
  transactionId  String  @map("transaction_id")
  productId      String  @map("product_id")
  productName    String  @map("product_name") // snapshot at sale time
  quantity       Decimal @db.Decimal(15, 3)
  sellUnitId     String? @map("sell_unit_id")
  sellUnitSymbol String? @map("sell_unit_symbol")
  unitPrice      Decimal @map("unit_price") @db.Decimal(15, 2)
  discount       Decimal @default(0) @db.Decimal(15, 2)
  tax            Decimal @default(0) @db.Decimal(15, 2)
  subtotal       Decimal @db.Decimal(15, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  sellUnit    Unit?       @relation(fields: [sellUnitId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@map("transaction_items")
}

/// Separate record for void/refund — original transaction header stays immutable.
model TransactionAdjustment {
  id              String         @id @default(uuid())
  transactionId   String         @map("transaction_id")
  type            AdjustmentType
  amount          Decimal        @db.Decimal(15, 2) // full or partial refund amount
  reason          String
  createdById     String         @map("created_by_id")
  approvedById    String?        @map("approved_by_id")
  createdAt       DateTime       @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  createdBy   User        @relation("AdjustmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy  User?       @relation("AdjustmentApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@map("transaction_adjustments")
}

enum AdjustmentType {
  VOID
  REFUND
}

model Payment {
  id            String        @id @default(uuid())
  transactionId String        @map("transaction_id")
  method        PaymentMethod
  amount        Decimal       @db.Decimal(15, 2)
  reference     String? // transfer ref, QRIS order ID, etc.
  createdAt     DateTime      @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("payments")
}

enum TransactionStatus {
  PENDING
  COMPLETED
  VOID
  REFUNDED
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
  E_WALLET
  CARD
  CREDIT
  DEPOSIT
}

// ─── Held Transactions (Hold Bill) ───────────────────────
// TTL enforced via expires_at; cron job releases expired holds.

model HeldTransaction {
  id               String   @id @default(uuid())
  outletId         String   @map("outlet_id")
  cashierId        String   @map("cashier_id")
  clientRequestId  String?  @map("client_request_id")
  label            String?
  subtotal  Decimal  @default(0) @db.Decimal(15, 2)
  discount  Decimal  @default(0) @db.Decimal(15, 2)
  tax       Decimal  @default(0) @db.Decimal(15, 2)
  total     Decimal  @default(0) @db.Decimal(15, 2)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  outlet  Outlet                @relation(fields: [outletId], references: [id], onDelete: Cascade)
  cashier User                  @relation(fields: [cashierId], references: [id], onDelete: Restrict)
  items   HeldTransactionItem[]

  @@unique([outletId, clientRequestId])
  @@index([outletId, expiresAt])
  @@index([cashierId])
  @@map("held_transactions")
}

model HeldTransactionItem {
  id                String  @id @default(uuid())
  heldTransactionId String  @map("held_transaction_id")
  productId         String  @map("product_id")
  productName       String  @map("product_name")
  quantity          Decimal @db.Decimal(15, 3)
  sellUnitId        String? @map("sell_unit_id")
  sellUnitSymbol    String? @map("sell_unit_symbol")
  unitPrice         Decimal @map("unit_price") @db.Decimal(15, 2)
  discount          Decimal @default(0) @db.Decimal(15, 2)
  subtotal          Decimal @db.Decimal(15, 2)

  heldTransaction HeldTransaction @relation(fields: [heldTransactionId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  sellUnit        Unit?           @relation(fields: [sellUnitId], references: [id], onDelete: SetNull)

  @@index([heldTransactionId])
  @@map("held_transaction_items")
}

// ─── Shift Management ────────────────────────────────────
// One open shift per cashier per outlet enforced at application layer.

model Shift {
  id           String    @id @default(uuid())
  outletId     String    @map("outlet_id")
  cashierId    String    @map("cashier_id")
  openingCash  Decimal   @map("opening_cash") @db.Decimal(15, 2)
  closingCash  Decimal?  @map("closing_cash") @db.Decimal(15, 2)
  expectedCash Decimal?  @map("expected_cash") @db.Decimal(15, 2)
  difference   Decimal?  @db.Decimal(15, 2)
  openedAt     DateTime  @default(now()) @map("opened_at")
  closedAt     DateTime? @map("closed_at")

  outlet       Outlet        @relation(fields: [outletId], references: [id], onDelete: Restrict)
  cashier      User          @relation(fields: [cashierId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@index([outletId, openedAt])
  @@index([cashierId, closedAt])
  @@map("shifts")
}

// ─── Audit Trail ─────────────────────────────────────────
// Append-only log for void, refund, price change, login events.

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  action     String // e.g. TRANSACTION_VOID, PRODUCT_UPDATE, USER_LOGIN
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json? // before/after snapshot or context
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ─── Offline Sync Queue (PWA) ──────────────────────────────
// Client-queued checkouts replayed idempotently via clientRequestId.
// Conflicts (e.g. stock) stored for manual resolve — server-wins policy per ADR-003.

model SyncQueueEntry {
  id              String             @id @default(uuid())
  tenantId        String             @map("tenant_id")
  outletId        String             @map("outlet_id")
  cashierId       String             @map("cashier_id")
  clientRequestId String             @map("client_request_id")
  operation       SyncQueueOperation
  payload         Json
  status          SyncQueueStatus    @default(PENDING)
  conflictCode    String?            @map("conflict_code")
  conflictMessage String?            @map("conflict_message")
  transactionId   String?            @map("transaction_id")
  deviceId        String?            @map("device_id")
  clientCreatedAt DateTime?          @map("client_created_at")
  processedAt     DateTime?          @map("processed_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  outlet  Outlet @relation(fields: [outletId], references: [id], onDelete: Restrict)
  cashier User   @relation(fields: [cashierId], references: [id], onDelete: Restrict)

  @@unique([outletId, clientRequestId])
  @@index([outletId, status])
  @@index([tenantId, createdAt])
  @@map("sync_queue_entries")
}

enum SyncQueueOperation {
  CHECKOUT_CASH
  CHECKOUT_SPLIT
  HOLD_BILL
  RECALL_HOLD
}

enum SyncQueueStatus {
  PENDING
  PROCESSING
  APPLIED
  CONFLICT
  FAILED
}

// ─── Online Orders (Epic J) ───────────────────────────────

model OnlineOrder {
  id                String                  @id @default(uuid())
  tenantId          String                  @map("tenant_id")
  outletId          String                  @map("outlet_id")
  orderNo           String                  @map("order_no")
  clientRequestId   String                  @map("client_request_id")
  status            OnlineOrderStatus       @default(NEW)
  fulfillmentType   OnlineFulfillmentType   @map("fulfillment_type")
  customerId        String?                 @map("customer_id")
  customerName      String                  @map("customer_name")
  customerPhone     String                  @map("customer_phone")
  customerNotes     String?                 @map("customer_notes")
  subtotal          Decimal                 @db.Decimal(15, 2)
  tax               Decimal                 @default(0) @db.Decimal(15, 2)
  shippingFee       Decimal                 @default(0) @map("shipping_fee") @db.Decimal(15, 2)
  total             Decimal                 @db.Decimal(15, 2)
  deliveryAddress   Json?                   @map("delivery_address")
  expiresAt         DateTime?               @map("expires_at")
  paidAt            DateTime?               @map("paid_at")
  completedAt       DateTime?               @map("completed_at")
  cancelledAt       DateTime?               @map("cancelled_at")
  cancelReason      String?                 @map("cancel_reason")
  midtransOrderId   String?                 @map("midtrans_order_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  outlet   Outlet               @relation(fields: [outletId], references: [id], onDelete: Restrict)
  customer Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OnlineOrderItem[]
  payments OnlineOrderPayment[]

  @@unique([tenantId, orderNo])
  @@unique([tenantId, clientRequestId])
  @@index([tenantId, status, createdAt])
  @@index([outletId, status, createdAt])
  @@map("online_orders")
}

model OnlineOrderItem {
  id            String  @id @default(uuid())
  onlineOrderId String  @map("online_order_id")
  productId     String  @map("product_id")
  productName   String  @map("product_name")
  sku           String
  quantity      Decimal @db.Decimal(15, 3)
  unitPrice     Decimal @map("unit_price") @db.Decimal(15, 2)
  subtotal      Decimal @db.Decimal(15, 2)

  onlineOrder OnlineOrder @relation(fields: [onlineOrderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([onlineOrderId])
  @@map("online_order_items")
}

model OnlineOrderPayment {
  id                    String               @id @default(uuid())
  onlineOrderId         String               @map("online_order_id")
  status                OnlinePaymentStatus  @default(PENDING)
  amount                Decimal              @db.Decimal(15, 2)
  midtransTransactionId String?              @map("midtrans_transaction_id")
  paymentType           String?              @map("payment_type")
  rawNotification       Json?                @map("raw_notification")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  onlineOrder OnlineOrder @relation(fields: [onlineOrderId], references: [id], onDelete: Cascade)

  @@unique([midtransTransactionId])
  @@index([onlineOrderId])
  @@map("online_order_payments")
}

model OnlineOrderSequence {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  sequenceDate DateTime @map("sequence_date") @db.Date
  lastValue    Int      @default(0) @map("last_value")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, sequenceDate])
  @@map("online_order_sequences")
}

enum OnlineOrderStatus {
  NEW
  PENDING_PAYMENT
  PAID
  CONFIRMED
  READY
  COMPLETED
  CANCELLED
  EXPIRED
}

enum OnlineFulfillmentType {
  PICKUP
  DELIVERY
}

enum OnlinePaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

// ─── Operating Expenses ───────────────────────────────────
// Onkos operasional toko — bongkar muat, kirim, operasional harian.

model Expense {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  outletId    String?         @map("outlet_id")
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(15, 2)
  description String?
  expenseDate DateTime        @map("expense_date") @db.Date
  createdById String          @map("created_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  outlet    Outlet? @relation(fields: [outletId], references: [id], onDelete: SetNull)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, expenseDate])
  @@index([tenantId, category, expenseDate])
  @@index([outletId, expenseDate])
  @@map("expenses")
}

enum ExpenseCategory {
  OPERATIONAL
  LOADING_UNLOADING
  SHIPPING
  OTHER
}

// ─── Credit, Receivables, Payables & Deposits (Fase 2) ──
// AR/AP scoped at tenant level; receivable may carry optional outletId for reporting.
// Immutable ledger — adjustments via payment/ledger records, not amount edits.

enum ReceivableStatus {
  OPEN
  PARTIAL
  PAID
  VOID
}

enum PayableStatus {
  OPEN
  PARTIAL
  PAID
  VOID
}

enum DepositAccountStatus {
  ACTIVE
  CLOSED
}

enum DepositTransactionType {
  TOP_UP
  APPLY
  REFUND
}

model Receivable {
  id            String           @id @default(uuid())
  tenantId      String           @map("tenant_id")
  customerId    String           @map("customer_id")
  outletId      String?          @map("outlet_id")
  transactionId String?          @unique @map("transaction_id")
  amount        Decimal          @db.Decimal(15, 2)
  paidAmount    Decimal          @default(0) @map("paid_amount") @db.Decimal(15, 2)
  status        ReceivableStatus @default(OPEN)
  dueDate       DateTime?        @map("due_date") @db.Date
  notes         String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer    Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  outlet      Outlet?             @relation(fields: [outletId], references: [id], onDelete: SetNull)
  transaction Transaction?        @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  payments    ReceivablePayment[]

  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, dueDate])
  @@index([outletId])
  @@map("receivables")
}

model ReceivablePayment {
  id           String        @id @default(uuid())
  receivableId String        @map("receivable_id")
  amount       Decimal       @db.Decimal(15, 2)
  method       PaymentMethod
  reference    String?
  recordedById String        @map("recorded_by_id")
  createdAt    DateTime      @default(now()) @map("created_at")

  receivable Receivable @relation(fields: [receivableId], references: [id], onDelete: Restrict)
  recordedBy User       @relation("ReceivablePaymentRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([receivableId, createdAt])
  @@map("receivable_payments")
}

model Payable {
  id         String        @id @default(uuid())
  tenantId   String        @map("tenant_id")
  supplierId String        @map("supplier_id")
  poId       String?       @unique @map("po_id")
  amount     Decimal       @db.Decimal(15, 2)
  paidAmount Decimal       @default(0) @map("paid_amount") @db.Decimal(15, 2)
  status     PayableStatus @default(OPEN)
  dueDate    DateTime?     @map("due_date") @db.Date
  notes      String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  supplier      Supplier         @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder?   @relation(fields: [poId], references: [id], onDelete: SetNull)
  payments      PayablePayment[]

  @@index([tenantId, status])
  @@index([tenantId, supplierId])
  @@index([tenantId, dueDate])
  @@map("payables")
}

model PayablePayment {
  id           String        @id @default(uuid())
  payableId    String        @map("payable_id")
  amount       Decimal       @db.Decimal(15, 2)
  method       PaymentMethod
  reference    String?
  recordedById String        @map("recorded_by_id")
  createdAt    DateTime      @default(now()) @map("created_at")

  payable    Payable @relation(fields: [payableId], references: [id], onDelete: Restrict)
  recordedBy User    @relation("PayablePaymentRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([payableId, createdAt])
  @@map("payable_payments")
}

model CustomerDeposit {
  id         String               @id @default(uuid())
  tenantId   String               @map("tenant_id")
  customerId String               @unique @map("customer_id")
  balance    Decimal              @default(0) @db.Decimal(15, 2)
  status     DepositAccountStatus @default(ACTIVE)
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  ledger   DepositTransaction[]

  @@index([tenantId, status])
  @@map("customer_deposits")
}

model DepositTransaction {
  id            String                 @id @default(uuid())
  depositId     String                 @map("deposit_id")
  type          DepositTransactionType
  amount        Decimal                @db.Decimal(15, 2)
  balanceAfter  Decimal                @map("balance_after") @db.Decimal(15, 2)
  referenceType String?                @map("reference_type")
  referenceId   String?                @map("reference_id")
  notes         String?
  recordedById  String                 @map("recorded_by_id")
  createdAt     DateTime               @default(now()) @map("created_at")

  deposit    CustomerDeposit @relation(fields: [depositId], references: [id], onDelete: Restrict)
  recordedBy User            @relation("DepositTransactionRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([depositId, createdAt])
  @@index([referenceType, referenceId])
  @@map("deposit_transactions")
}
