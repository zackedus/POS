{
  "name": "@barokah/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File ../../scripts/dev-api-safe.ps1 -Port 3000 -ProjectRoot ../.. -StartCommand \"npm run dev --workspace=@barokah/api\"",
    "dev:fallback": "powershell -ExecutionPolicy Bypass -File ../../scripts/dev-api-safe.ps1 -Port 3000 -AutoFallback -ProjectRoot ../.. -StartCommand \"npm run dev --workspace=@barokah/api\"",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@barokah/database": "*",
    "@barokah/shared": "*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/websockets": "^11.1.24",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.11.0",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0"
  }
}
