# Staging environment template — Barokah Core POS
# Copy to docker/.env.staging and adjust secrets before deploy

# ─── Database ───
POSTGRES_USER=barokah
POSTGRES_PASSWORD=change-me-staging-strong
POSTGRES_DB=barokah_pos_staging

# ─── API ───
JWT_SECRET=change-me-staging-jwt-min-32-chars
JWT_REFRESH_SECRET=change-me-staging-refresh-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=production

# ─── Midtrans (sandbox for staging) ───
MIDTRANS_SERVER_KEY=SB-Mid-server-xxx
MIDTRANS_IS_PRODUCTION=false

# ─── SMTP (optional — omit for console mock) ───
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@staging.barokah.local

# ─── Web ───
NEXT_PUBLIC_API_URL=http://localhost:3000
SEED_DATABASE=true

# ─── Realtime ───
SOCKET_ENABLED=true
