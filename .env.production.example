# Production environment template — Barokah Core POS
# Copy to .env (or inject via CI/secrets manager). NEVER commit real secrets.

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://barokah:CHANGE_ME_STRONG@postgres:5432/barokah_pos

# ── Cache / Queue ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# REDIS_DISABLED=false  # production must use Redis for BullMQ jobs

# ── Auth (JWT) ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_REFRESH
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── API ───────────────────────────────────────────────────────
API_PORT=3000
API_URL=https://api.your-domain.id
NODE_ENV=production

# ── Web (Next.js) ─────────────────────────────────────────────
WEB_PORT=3001
NEXT_PUBLIC_API_URL=https://api.your-domain.id

# ── Mobile (Expo) ─────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://api.your-domain.id

# ── Midtrans (live — isi setelah Pak Zaki punya key sandbox/live) ──
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_WEBHOOK_SKIP_VERIFY=false
STOREFRONT_BASE_URL=https://toko.your-domain.id

# ── SMTP (laporan mingguan — opsional) ────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.id

# ── Realtime ──────────────────────────────────────────────────
SOCKET_ENABLED=true

# ── Seed (production: false) ──────────────────────────────────
SEED_DATABASE=false
