# Environment variables — copy to .env and fill values

# ── Database ─────────────────────────────────────────────────
# Default: local PostgreSQL or Docker (see docker/docker-compose.dev.yml)
DATABASE_URL=postgresql://barokah:barokah@localhost:5432/barokah_pos
# If local PostgreSQL 18 already uses port 5432, map Docker to 5433 and use:
# DATABASE_URL=postgresql://barokah:barokah@localhost:5433/barokah_pos

# ── Cache / Queue ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_DISABLED=true  # paksa inline fallback (tanpa BullMQ) — berguna CI/test
# npm run dev otomatis set REDIS_DISABLED=true jika Redis/Docker tidak tersedia

# ── Auth (JWT) ────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── API ───────────────────────────────────────────────────────
API_PORT=3000
API_URL=http://localhost:3000

# ── Web (Next.js) ─────────────────────────────────────────────
WEB_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Mobile (Expo) ─────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── Runtime ───────────────────────────────────────────────────
NODE_ENV=development

# ── Midtrans (storefront online payment) ──────────────────────
# Kosongkan MIDTRANS_SERVER_KEY untuk mock mode (dev/UAT tanpa sandbox key).
# Isi dengan Server Key sandbox Midtrans untuk redirect Snap live.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_WEBHOOK_SKIP_VERIFY=true
STOREFRONT_BASE_URL=http://localhost:3001

# ── Docker full stack (docker/docker-compose.yml) ─────────────
# Internal URLs (inside Docker network) — set automatically by compose.
# DATABASE_URL=postgresql://barokah:barokah@postgres:5432/barokah_pos
# REDIS_URL=redis://redis:6379
#
# Browser-facing (host machine):
# NEXT_PUBLIC_API_URL=http://localhost:3000
# SEED_DATABASE=true   # run prisma seed on first db-migrate (dev/demo only)
